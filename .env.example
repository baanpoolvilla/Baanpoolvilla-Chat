# ─── Database ───────────────────────────────────────────
DATABASE_URL="postgresql://chatuser:change_me_strong_password@postgres:5432/unified_chat"
DB_PASSWORD=change_me_strong_password

# ─── Redis ──────────────────────────────────────────────
REDIS_URL="redis://:change_me_redis_password@redis:6379"
REDIS_PASSWORD=change_me_redis_password

# ─── Auth ───────────────────────────────────────────────
JWT_SECRET=change_me_min_32_chars_random_string
JWT_REFRESH_SECRET=change_me_another_random_string
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ─── LINE ───────────────────────────────────────────────
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_ACCESS_TOKEN=

# ─── Facebook / Instagram (Meta) ────────────────────────
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=random_string_you_choose
META_PAGE_ACCESS_TOKEN=

# ─── TikTok ─────────────────────────────────────────────
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=

# ─── AI Bot (at least one) ──────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEFAULT_AI_PROVIDER=openai
DEFAULT_AI_MODEL=gpt-4o

# ─── Server ─────────────────────────────────────────────
NODE_ENV=production
PORT=3001
NEXT_PUBLIC_API_URL=https://your-domain.com/api
NEXT_PUBLIC_SOCKET_URL=https://your-domain.com

# ─── Optional: Cloudflare Tunnel (no SSL cert needed) ───
# Run: cloudflared tunnel --url http://localhost:80
